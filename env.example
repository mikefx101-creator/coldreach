# ─── SUPABASE ──────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# ─── GMAIL CREDENTIALS ─────────────────────────────────────────────────────
# Add your Gmail email and app passwords here
# Format: APP_PASSWORD_EMAILNAME (remove @ and .)
# Example: If email is mike@gmail.com, use APP_PASSWORD_MIKE

APP_PASSWORD_MIKE=your-app-password-here
APP_PASSWORD_HELLO=your-app-password-here
APP_PASSWORD_OUTREACH=your-app-password-here

# ─── SERVER ────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production
